MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/devmeet?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379

# Execution provider: "docker" (default) or "wandbox" (fallback)
EXECUTION_PROVIDER=docker

# Wandbox fallback URL (only used when EXECUTION_PROVIDER=wandbox or for unsupported languages)
WANDBOX_API_URL=https://wandbox.org/api/compile.json

# Docker sandbox limits
EXECUTION_TIMEOUT_MS=5000
EXECUTION_MEMORY_MB=128
EXECUTION_CPU_LIMIT=0.5
EXECUTION_MAX_CODE_SIZE_KB=64
EXECUTION_MAX_STDIN_SIZE_KB=16
EXECUTION_MAX_OUTPUT_SIZE_KB=64

NODE_ENV=development
