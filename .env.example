# ──────────────────────────────────────────────────────────────
# DevMeet Environment Variables
# Copy this file to .env in apps/server/ and apps/worker/ and fill in values.
# ──────────────────────────────────────────────────────────────

# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# JWT Authentication Secret
# Generate a secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Stream Video & Chat (Video Conferencing)
# Get these from https://getstream.io/dashboard/
VITE_STREAM_VIDEO_API_KEY=your_stream_api_key
STREAM_VIDEO_API_KEY=your_stream_api_key
STREAM_VIDEO_API_SECRET=your_stream_api_secret

# AI Providers (At least one is required. Multiple enables fallback)
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Redis Configuration (For Rate Limiting & BullMQ Job Queue)
REDIS_URL=redis://localhost:6379
RATE_LIMIT_ENABLED=true

# Resend (Email Verification / OTP)
# Get this from https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ── Worker-specific (apps/worker/.env) ───────────────────────

# Execution provider: "docker" (default)
EXECUTION_PROVIDER=docker

# Sandbox resource limits
EXECUTION_TIMEOUT_MS=5000
EXECUTION_MEMORY_MB=128
EXECUTION_CPU_LIMIT=0.5
EXECUTION_MAX_CODE_SIZE_KB=64
EXECUTION_MAX_STDIN_SIZE_KB=16
EXECUTION_MAX_OUTPUT_SIZE_KB=64
